# Canonical raw transcript file location for future pipeline use.
TRANSCRIPT_RAW_PATH=data/raw/earnings_calls_full_5year_with_revenue.csv

# Optional WRDS username for true component-level transcript pulls.
WRDS_USERNAME=

# Optional preferred location for a true component-level transcript export.
TRANSCRIPT_COMPONENTS_PATH=data/interim/wrds_transcript_components.csv

# Optional fallback while the current large transcript file still lives at data/.
TRANSCRIPT_LEGACY_PATH=data/earnings_calls_full_5year_with_revenue.csv

# Optional external datasets for later finance work.
RETURNS_DATA_PATH=data/external/returns.parquet
FUNDAMENTALS_DATA_PATH=data/external/fundamentals.parquet
ANALYST_DATA_PATH=data/external/analyst_data.parquet
